{
  "name": "kira-desktop",
  "version": "0.1.0",
  "description": "Electron shell hosting the Kira autonomous agent UI",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "wait-on http://localhost:5173 && electron .",
    "build": "vite build --config vite.config.ts && electron-builder",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron": "^28.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron-builder": "^24.13.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2"
  }
}
